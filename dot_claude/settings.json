{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebSearch",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chezmoi:*)",
      "Bash(test:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(date:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(python:*)",
      "Bash(printenv:*)",
      "Bash(basename:*)",
      "Bash(gh:*)",
      "Bash(uname:*)",
      "Bash(wsl:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.local.*)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Read(**/.env.staging)",
      "Read(**/.env.prod)",
      "Read(**/.env.dev)",
      "Read(**/.env.test)",
      "Read(**/secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('obsidian-log-hook')\"",
            "timeout": 30,
            "statusMessage": "作業ログを自動記録中..."
          },
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('context-save-hook')\"",
            "timeout": 30,
            "statusMessage": "コンテキストを自動保存中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('obsidian-log-hook')\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('context-save-hook')\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('context-save-reminder')\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('claude-md-audit-reminder')\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('notification-hook')\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "dotnet@dotnet-agent-skills": true,
    "dotnet-aspnet@dotnet-agent-skills": true,
    "microsoft-docs@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
