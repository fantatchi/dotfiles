{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebSearch",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chezmoi:*)",
      "Bash(test:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(date:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(python:*)",
      "Bash(printenv:*)",
      "Bash(basename:*)",
      "Bash(gh:*)",
      "Bash(uname:*)",
      "Bash(wsl:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.local.*)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Read(**/.env.staging)",
      "Read(**/.env.prod)",
      "Read(**/.env.dev)",
      "Read(**/.env.test)",
      "Read(**/secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('context-save-reminder')\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('claude-md-audit-reminder')\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('typecheck-gate')\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('os').homedir()+'/.claude/scripts/run-hook.js')('notification-hook')\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "skill-creator@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "dotnet@dotnet-agent-skills": true,
    "dotnet-aspnet@dotnet-agent-skills": true,
    "microsoft-docs@claude-plugins-official": true,
    "codex@openai-codex": true,
    "modern-web-guidance@googlechrome": true,
    "claude-code-setup@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      },
      "autoUpdate": true
    },
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "googlechrome": {
      "source": {
        "source": "github",
        "repo": "GoogleChrome/modern-web-guidance"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true
}
