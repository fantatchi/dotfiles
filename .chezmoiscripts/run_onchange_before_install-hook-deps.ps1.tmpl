{{- if ne .chezmoi.os "windows" -}}
{{- /* Windows 以外では実行しない（空出力でスキップ） */ -}}
{{- else -}}
Write-Host "=== Claude Code hook の依存チェック ==="

# --- PowerShell ExecutionPolicy 確認 ---
# Restricted / Undefined だと Claude Code の Stop hook（BurntToast 通知）が起動しない。
$policy = Get-ExecutionPolicy -Scope CurrentUser
if ($policy -in @('Restricted', 'Undefined')) {
    Write-Warning "CurrentUser の ExecutionPolicy が $policy です。Claude Code の Stop hook（BurntToast 通知）が起動しない可能性があります。"
    Write-Warning "以下を実行してください: Set-ExecutionPolicy -Scope CurrentUser -ExecutionPolicy RemoteSigned"
}

# --- Windows 依存 ---
Write-Host ""
Write-Host "[Windows]"

if (Get-Module -ListAvailable -Name BurntToast) {
    Write-Host "  [OK] BurntToast"
} else {
    Write-Host "  [INSTALL] BurntToast"
    Install-Module -Name BurntToast -Force -Scope CurrentUser
}

# --- Linux 依存（WSL 環境のみ） ---
if (Get-Command wsl -ErrorAction SilentlyContinue) {
    Write-Host ""
    Write-Host "[Linux via WSL]"

    $jqCheck = wsl -- bash -c "command -v jq" 2>$null
    if ($jqCheck) {
        Write-Host "  [OK] jq"
    } else {
        Write-Host "  [INSTALL] jq"
        wsl -- sudo apt-get update -qq
        wsl -- sudo apt-get install -y -qq jq
    }
}

Write-Host ""
Write-Host "依存チェック完了"
{{ end -}}
